diff --git a/bsp/abstract-machine/include/time.h b/bsp/abstract-machine/include/time.h
new file mode 100644
index 0000000..546bbff
--- /dev/null
+++ b/bsp/abstract-machine/include/time.h
@@ -0,0 +1,36 @@
+#ifndef __AM_RTTHREAD_TIME_H__
+#define __AM_RTTHREAD_TIME_H__
+
+#include <stddef.h>
+
+typedef long time_t;
+typedef long clock_t;
+
+struct tm {
+  int tm_sec;
+  int tm_min;
+  int tm_hour;
+  int tm_mday;
+  int tm_mon;
+  int tm_year;
+  int tm_wday;
+  int tm_yday;
+  int tm_isdst;
+};
+
+struct timespec {
+  time_t tv_sec;
+  long tv_nsec;
+};
+
+clock_t clock(void);
+double difftime(time_t time1, time_t time0);
+time_t mktime(struct tm *timeptr);
+time_t time(time_t *timer);
+char *asctime(const struct tm *timeptr);
+char *ctime(const time_t *timer);
+struct tm *gmtime(const time_t *timer);
+struct tm *localtime(const time_t *timer);
+size_t strftime(char *s, size_t max, const char *format, const struct tm *tm);
+
+#endif
diff --git a/bsp/abstract-machine/src/context.c b/bsp/abstract-machine/src/context.c
index ee38829..0ba032e 100644
--- a/bsp/abstract-machine/src/context.c
+++ b/bsp/abstract-machine/src/context.c
@@ -2,11 +2,25 @@
 #include <klib.h>
 #include <rtthread.h>
 
+static Context **switch_from = NULL;
+static Context **switch_to = NULL;
+
 static Context* ev_handler(Event e, Context *c) {
   switch (e.event) {
+    case EVENT_YIELD: {
+      Context **from = switch_from;
+      Context **to = switch_to;
+      switch_from = NULL;
+      switch_to = NULL;
+
+      if (from != NULL) {
+        *from = c;
+      }
+      assert(to != NULL && *to != NULL);
+      return *to;
+    }
     default: printf("Unhandled event ID = %d\n", e.event); assert(0);
   }
-  return c;
 }
 
 void __am_cte_init() {
@@ -14,11 +28,15 @@ void __am_cte_init() {
 }
 
 void rt_hw_context_switch_to(rt_ubase_t to) {
-  assert(0);
+  switch_from = NULL;
+  switch_to = (Context **)to;
+  yield();
 }
 
 void rt_hw_context_switch(rt_ubase_t from, rt_ubase_t to) {
-  assert(0);
+  switch_from = (Context **)from;
+  switch_to = (Context **)to;
+  yield();
 }
 
 void rt_hw_context_switch_interrupt(void *context, rt_ubase_t from, rt_ubase_t to, struct rt_thread *to_thread) {
@@ -26,6 +44,27 @@ void rt_hw_context_switch_interrupt(void *context, rt_ubase_t from, rt_ubase_t t
 }
 
 rt_uint8_t *rt_hw_stack_init(void *tentry, void *parameter, rt_uint8_t *stack_addr, void *texit) {
-  assert(0);
-  return NULL;
+  extern void __am_rt_thread_entry(void);
+
+  uintptr_t top = (uintptr_t)stack_addr + sizeof(rt_ubase_t);
+  top = top / sizeof(uintptr_t) * sizeof(uintptr_t);
+  Context *c = kcontext((Area) { NULL, (void *)top },
+      (void (*)(void *))__am_rt_thread_entry, parameter);
+
+  c->gpr[8] = (uintptr_t)tentry;
+  c->gpr[9] = (uintptr_t)texit;
+  return (rt_uint8_t *)c;
+}
+
+#if defined(__riscv)
+asm(
+  ".globl __am_rt_thread_entry\n"
+  "__am_rt_thread_entry:\n"
+  "  jalr ra, s0, 0\n"
+  "  jalr zero, s1, 0\n"
+);
+#else
+void __am_rt_thread_entry(void) {
+  panic("RT-Thread context entry is only implemented for RISC-V");
 }
+#endif
diff --git a/components/libc/compilers/common/extension/sys/errno.h b/components/libc/compilers/common/extension/sys/errno.h
