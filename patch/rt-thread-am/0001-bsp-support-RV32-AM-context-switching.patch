--- a/components/libc/compilers/common/extension/sys/errno.h
+++ b/components/libc/compilers/common/extension/sys/errno.h
@@ -38,9 +38,7 @@ defined in armcc/errno.h
 #define ERROR_BASE_NO    0
 #endif
 
-#if defined(__ARMCC_VERSION) || defined(__IAR_SYSTEMS_ICC__)
-#include <errno.h>
-
+#if !defined(_WIN32)
 #ifndef EPERM
 #define EPERM            (ERROR_BASE_NO + 1)
 #endif
